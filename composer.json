{
    "name": "behindsolution/laragrep",
    "description": "Transform natural language questions into safe parameterized SQL queries using AI.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "LaraGrep\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaraGrep\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaraGrep\\LaraGrepServiceProvider"
            ]
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0"
    }
}
